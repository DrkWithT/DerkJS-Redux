module;

#include <string_view>

export module core.polyfills;

namespace DerkJS::Core {
    export constexpr std::string_view polyfill_code = "\n"
    "function isNaN(arg) {\n"
        "if (arg instanceof Array) {\n"
            "return false;\n"
        "}\n"
        "\n"
        "return +arg !== +arg;\n"
    "}\n"
    "function Error(msg) {\n"
        "if (this === globalThis) {\n" //? NOTE: a normal vs. ctor status of this call determines self 
            "var self = Object.create(Error.prototype);\n"
        "} else {\n"
            "var self = this;\n"
        "}\n"
        "if (msg !== undefined) {\n"
            "self.message = new String(msg);\n"
        "} else {\n"
            "self.message = '';\n"
        "}\n"
    "}\n"
    "function SyntaxError(msg) {\n"
        "if (this === globalThis) {\n" //? NOTE: a normal vs. ctor status of this call determines self 
        "var self = Object.create(SyntaxError.prototype);\n"
        "} else {\n"
        "var self = this;\n"
        "}\n"
        "if (msg !== undefined) {\n"
            "self.message = new String(msg);\n"
        "} else {\n"
            "self.message = '';\n"
        "}\n"
    "}\n"
    "function TypeError(msg) {\n"
        "if (this === globalThis) {\n" //? NOTE: a normal vs. ctor status of this call determines self 
        "var self = Object.create(TypeError.prototype);\n"
        "} else {\n"
        "var self = this;\n"
        "}\n"
        "if (msg !== undefined) {\n"
            "self.message = new String(msg);\n"
        "} else {\n"
            "self.message = '';\n"
        "}\n"
    "}\n"
    "function ReferenceError(msg) {\n"
        "if (this === globalThis) {\n" //? NOTE: a normal vs. ctor status of this call determines self 
        "var self = Object.create(ReferenceError.prototype);\n"
        "} else {\n"
        "var self = this;\n"
        "}\n"
        "if (msg !== undefined) {\n"
            "self.message = new String(msg);\n"
        "} else {\n"
            "self.message = '';\n"
        "}\n"
    "}\n"
    "function displayAnyError() {\n"
        "return '' + this.name + ': ' + this.message;\n"
    "}\n"
    "Object.prototype.toString = function () {\n"
        "if (this === undefined) {\n"
            "return '[object Undefined]';\n"
        "} else if (this === null) {\n"
            "return '[object Null]';\n"
        "} else {\n"
            "return '[object Object]';\n"
        "}\n"
    "};\n"
    "Object.prototype.constructor = Object;\n"
    "Boolean.prototype.toString = function () {\n"
        "if (this instanceof Boolean) {\n"
            "return new String(this.valueOf());\n"
        "}\n"
        "throw new TypeError('Boolean.prototype.toString requires Boolean this.');\n"
    "};\n"
    "Boolean.prototype.constructor = Boolean;\n"
    "Number.NaN = NaN;\n"
    "Number.prototype.toString = function () {\n"
        "if (this instanceof Number) {\n"
            "return new String(this.valueOf());\n"
        "}\n"
        "throw new TypeError('Number.prototype.toString requires Number this.');\n"
    "};\n"
    "Number.prototype.constructor = Number;\n"
    "String.prototype.valueOf = function () {\n"
        "if (this instanceof String) {\n"
            "return new String(this);\n"
        "}\n"
        "throw new TypeError('String.prototype.toString requires String this.');\n"
    "};\n"
    "String.prototype.charAt = function (pos) {\n"
        "var posInt = toInt32(pos), len = this.length;\n"
        "if (posInt < 0 || posInt >= len) return new String('');\n"
        "return this.substring(posInt, posInt + 1);\n"
    "};\n"
    "String.prototype.toString = String.prototype.valueOf;\n"
    "String.prototype.constructor = String;\n"
    "Array.isArray = function (arg) {\n"
        "if (typeof arg !== 'object') {\n"
            "return false;\n"
        "}\n"
        "return arg instanceof Array;\n"
    "};\n"
    "Array.prototype.at = function(index) {\n"
        "if (index < 0) {\n"
            "index = index + this.length;\n"
        "}\n"
        "return this[index];\n"
    "};\n"
    "Array.prototype.pop = function() {\n"
        "var old = this.at(-1);\n"
        "this.length = this.length - 1;\n"
        "return old;\n"
    "};\n"
    "Array.prototype.indexOf = function (item, fromIndex) {\n"
        "var pos = fromIndex;\n"
        "var end = this.length;\n"
        "var result = -1;\n"
        "if (!pos || pos < 0) {\n"
            "pos = 0;\n"
        "}\n"
        "while (pos < end) {\n"
            "if (this.at(pos) === item) {\n"
                "result = pos;\n"
                "break;\n"
            "}\n"
            "++pos;\n"
        "}\n"
        "return result;\n"
    "};\n"
    "Array.prototype.lastIndexOf = function (item, fromIndex) {\n"
        "var pos;\n"
        "var end = -1;\n"
        "var result = -1;\n"
        "if (fromIndex === undefined || fromIndex === null) {\n"
            "pos = this.length - 1;\n"
        "} else if (fromIndex >= 0) {\n"
            "pos = +fromIndex;\n"
        "} else {\n"
            "pos = this.length - (0 - fromIndex);\n"
        "}\n"
        "if (pos > this.length - 1) {\n"
            "pos = this.length - 1;\n"
        "}\n"
        "while (pos > end) {\n"
            "if (this[pos] === item) {\n"
                "result = pos;\n"
                "break;\n"
            "}\n"
            "--pos;\n"
        "}\n"
        "return result;\n"
    "};\n"
    "Array.prototype.reverse = function () {\n"
        "var left = 0;\n"
        "var right = this.length - 1;\n"
        "var temp;\n"
        "while (left < right) {\n"
            "temp = this[left];\n"
            "this[left] = this[right];\n"
            "this[right] = temp;\n"
            "++left;\n"
            "--right;\n"
        "}\n"
        "return this;\n"
    "};\n"
    "Array.prototype.forEach = function (callbackFn, thisArg) {\n"
        "for (var i = 0, end = this.length; i < end; ++i) {\n"
            "var discard = callbackFn.call(thisArg, this[i], i, this);\n"
        "}\n"
        "return undefined;\n"
    "};\n"
    "Array.prototype.some = function(callbackFn, thisArg) {\n"
    "for (var i = 0, end = this.length; i < end; ++i) {\n"
        "var temp = this[i];\n"
        "if (temp !== undefined) {\n"
            "if (callbackFn.call(thisArg, temp, i, this)) return true;\n"
        "}\n"
    "}\n"
    "return false;\n"
    "};\n"
    "Array.prototype.every = function(callbackFn, thisArg) {\n"
    "for (var i = 0, end = this.length; i < end; ++i) {\n"
        "var temp = this[i];\n"
        "if (temp !== undefined) {\n"
            "if (!callbackFn.call(thisArg, temp, i, this)) return false;\n"
        "}\n"
    "}\n"
    "return true;\n"
    "};\n"
    "Array.prototype.map = function (callbackFn, thisArg) {\n"
        "var a = [];\n"
        "for (var i = 0, end = this.length; i < end; ++i) {\n"
            "var temp = this[i];\n"
            "if (temp !== undefined) {\n"
                "var discard = a.push(callbackFn.call(thisArg, this[i], i , this));\n"
            "}\n"
        "}\n"
        "return a;\n"
    "};\n"
    "Array.prototype.filter = function (predicateFn, thisArg) {\n"
        "var a = [];\n"
        "for (var i = 0, end = this.length; i < end; ++i) {\n"
            "var item = this[i];\n"
            "if (item !== undefined) {\n"
                "if (predicateFn.call(thisArg, item, i, this)) a.push(item);\n"
            "}\n"
        "}\n"
        "return a;\n"
    "};\n"
    "Array.prototype.toString = function () {\n"
        "if (typeof this.join === 'function') {\n"
            "return this.join();\n"
        "}\n"
        "return '[object Object]';\n"
    "};\n"
    "Array.prototype.constructor = Array;\n"
    "Function.prototype.toString = function () {\n"
        "return new String(this);\n"
    "};\n"
    "Function.prototype.constructor = Function;\n"
    "Error.prototype = {\n"
        "name: 'Error',\n"
        "message: '',\n"
        "constructor: Error,\n"
        "toString: displayAnyError\n"
    "};\n"
    "SyntaxError.prototype = {\n"
        "name: 'SyntaxError',\n"
        "message: '',\n"
        "constructor: SyntaxError,\n"
        "toString: displayAnyError\n"
    "};\n"
    "TypeError.prototype = {\n"
        "name: 'TypeError',\n"
        "message: '',\n"
        "constructor: TypeError,\n"
        "toString: displayAnyError\n"
    "};\n"
    "ReferenceError.prototype = {\n"
        "name: 'ReferenceError',\n"
        "message: '',\n"
        "constructor: ReferenceError,\n"
        "toString: displayAnyError\n"
    "};\n"
    "console.log = function (...args) {\n"
        "var argCount = args.length;\n"
        "var temp;\n"
        "var discard;\n"
        "for (var argPos = 0; argPos < argCount; ++argPos) {\n"
            "temp = args.at(argPos);\n"
            "if (temp === null) {\n"
                "discard = nativePrint('null', 32);\n"
            "} else if (typeof temp === 'object') {\n"
                "discard = nativePrint(temp.toString(), 32);\n"
            "} else {\n"
                "discard = nativePrint(temp, 32);\n"
            "}\n"
        "}\n"
        "discard = nativePrint(' ', 10);\n"
        "return discard; // undefined\n"
    "};\n"
    "console.readln = nativeReadLine;\n"
    "Object.freeze(Object);\n"
    "Object.freeze(Boolean);\n"
    "Object.freeze(Number);\n"
    "Object.freeze(String);\n"
    "Object.freeze(Array);\n"
    "Object.freeze(Function);\n"
    "Object.freeze(Error);\n"
    "Object.freeze(SyntaxError);\n"
    "Object.freeze(TypeError);\n"
    "Object.freeze(ReferenceError);\n"
    "\n";
}
